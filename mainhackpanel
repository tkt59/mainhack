local function createTab(name, icon)
    local btn = Instance.new("TextButton")
    btn.Size             = UDim2.new(0, 95, 0, 26)
    btn.BackgroundColor3 = Color3.fromRGB(32, 32, 46)
    btn.BorderSizePixel  = 0
    btn.Text             = icon .. " " .. name
    btn.TextColor3       = Color3.fromRGB(160, 160, 185)
    btn.TextSize         = 13
    btn.Font             = Enum.Font.GothamSemibold
    btn.Parent           = TabsFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
 
    local content = Instance.new("Frame")
    content.Size             = UDim2.new(1, 0, 0, 0)
    content.BackgroundTransparency = 1
    content.Visible          = false
    content.AutomaticSize    = Enum.AutomaticSize.Y
    content.Parent           = ContentFrame
 
    local lay = Instance.new("UIListLayout")
    lay.Padding   = UDim.new(0, 8)
    lay.SortOrder = Enum.SortOrder.LayoutOrder
    lay.Parent    = content
 
    tabContents[name] = content
    tabButtons[name]  = btn
 
    btn.MouseButton1Click:Connect(function()
        for n, c in pairs(tabContents) do
            c.Visible = false
            tabButtons[n].BackgroundColor3 = Color3.fromRGB(32, 32, 46)
            tabButtons[n].TextColor3       = Color3.fromRGB(160, 160, 185)
        end
        content.Visible          = true
        activeTab                = name
        btn.BackgroundColor3     = Color3.fromRGB(75, 75, 175)
        btn.TextColor3           = Color3.fromRGB(255, 255, 255)
    end)
 
    return content
end
 
