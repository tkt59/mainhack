--       HEARTBEAT PRINCIPAL
-- ══════════════════════════════════════════
 
RunService.Heartbeat:Connect(function(dt)
    local char = LocalPlayer.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char.PrimaryPart
 
    -- Infos position
    if root then
        local p = root.Position
        infoLbl.Text = string.format("  Pos: %.1f, %.1f, %.1f  |  Joueurs: %d", p.X, p.Y, p.Z, #Players:GetPlayers())
    end
 
    -- ── FLY SANS RAGDOLL ──
    -- Utilise BodyVelocity + BodyGyro mais SANS PlatformStand
    if flyEnabled and char and root and hum then
        local cam = workspace.CurrentCamera
 
        -- BodyVelocity
        local bv = root:FindFirstChild("FlyBV")
        if not bv then
            bv           = Instance.new("BodyVelocity")
            bv.Name      = "FlyBV"
            bv.MaxForce  = Vector3.new(1e6, 1e6, 1e6)
            bv.Velocity  = Vector3.new(0, 0, 0)
            bv.Parent    = root
        end
 
        -- BodyGyro (orientation)
        local bg = root:FindFirstChild("FlyBG")
        if not bg then
            bg           = Instance.new("BodyGyro")
            bg.Name      = "FlyBG"
            bg.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
            bg.P         = 3e4
            bg.D         = 800
            bg.Parent    = root
        end
 
        local dir = Vector3.new()
        if UserInputService:IsKeyDown(Enum.KeyCode.W)         then dir = dir + cam.CFrame.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.S)         then dir = dir - cam.CFrame.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.A)         then dir = dir - cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D)         then dir = dir + cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space)     then dir = dir + Vector3.new(0, 1, 0)  end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0, 1, 0)  end
 
        bv.Velocity = dir.Magnitude > 0 and dir.Unit * flySpeed or Vector3.new(0, 0, 0)
        bg.CFrame   = cam.CFrame
 
        -- NE PAS mettre PlatformStand = true (causerait le ragdoll)
        -- On force l'état Running pour éviter que le hum tombe
        hum:ChangeState(Enum.HumanoidStateType.Running)
 
    elseif not flyEnabled and char and root then
        -- Supprime les contraintes quand fly est off
        local bv = root:FindFirstChild("FlyBV")
        local bg = root:FindFirstChild("FlyBG")
        if bv then bv:Destroy() end
        if bg then bg:Destroy() end
    end
 
    -- ── JUMP POWER (forcé en continu) ──
    if jumpEnabled and hum then
        hum.JumpPower = jumpValue
    end
 
    -- ── NOCLIP ──
    if noclipEnabled and char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
 
    -- ── INVISIBLE (maintenu si perso reload) ──
    if invisEnabled and char then
        for _, part in ipairs(char:GetDescendants()) do
            if (part:IsA("BasePart") or part:IsA("Decal")) and part.Name ~= "HumanoidRootPart" then
                part.Transparency = 1
            end
        end
    end
end)
 
