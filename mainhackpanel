local function refreshPlayerList()
    for _, child in ipairs(playerListFrame:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
 
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local row = Instance.new("Frame")
            row.Size             = UDim2.new(1, 0, 0, 38)
            row.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
            row.BorderSizePixel  = 0
            row.Parent           = playerListFrame
            Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)
 
            local nameLbl = Instance.new("TextLabel")
            nameLbl.Size             = UDim2.new(1, -162, 1, 0)
            nameLbl.Position         = UDim2.new(0, 10, 0, 0)
            nameLbl.BackgroundTransparency = 1
            nameLbl.Text             = "👤 " .. plr.Name
            nameLbl.TextColor3       = Color3.fromRGB(215, 215, 235)
            nameLbl.TextSize         = 13
            nameLbl.Font             = Enum.Font.Gotham
            nameLbl.TextXAlignment   = Enum.TextXAlignment.Left
            nameLbl.Parent           = row
 
            -- Bouton TP
            local tpBtn = Instance.new("TextButton")
            tpBtn.Size             = UDim2.new(0, 42, 0, 24)
            tpBtn.Position         = UDim2.new(1, -158, 0.5, -12)
            tpBtn.BackgroundColor3 = Color3.fromRGB(50, 95, 50)
            tpBtn.BorderSizePixel  = 0
            tpBtn.Text             = "TP"
            tpBtn.TextColor3       = Color3.fromRGB(190, 255, 190)
            tpBtn.TextSize         = 12
            tpBtn.Font             = Enum.Font.GothamBold
            tpBtn.Parent           = row
            Instance.new("UICorner", tpBtn).CornerRadius = UDim.new(0, 6)
 
            -- Bouton Spectate
            local specBtn = Instance.new("TextButton")
            specBtn.Size             = UDim2.new(0, 76, 0, 24)
            specBtn.Position         = UDim2.new(1, -108, 0.5, -12)
            specBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 130)
            specBtn.BorderSizePixel  = 0
            specBtn.Text             = "Spectate"
            specBtn.TextColor3       = Color3.fromRGB(190, 190, 255)
            specBtn.TextSize         = 11
            specBtn.Font             = Enum.Font.GothamBold
            specBtn.Parent           = row
            Instance.new("UICorner", specBtn).CornerRadius = UDim.new(0, 6)
 
            tpBtn.MouseButton1Click:Connect(function()
                local char  = LocalPlayer.Character
                local tChar = plr.Character
                if char and tChar and tChar.PrimaryPart then
                    char:SetPrimaryPartCFrame(tChar.PrimaryPart.CFrame + Vector3.new(0, 3, 0))
                end
            end)
 
            specBtn.MouseButton1Click:Connect(function()
                if spectateConn then spectateConn:Disconnect() end
                spectating = true
                workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
                spectateConn = RunService.RenderStepped:Connect(function()
                    if plr.Character and plr.Character:FindFirstChildOfClass("Humanoid") then
                        workspace.CurrentCamera.CameraType    = Enum.CameraType.Watch
                        workspace.CurrentCamera.CameraSubject = plr.Character:FindFirstChildOfClass("Humanoid")
                    end
                end)
            end)
        end
    end
end
 
