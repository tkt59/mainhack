local function refreshPlayerList()
    for _, child in ipairs(playerListFrame:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local row = Instance.new("Frame")
            row.Size = UDim2.new(1, 0, 0, 38)
            row.BackgroundColor3 = Color3.fromRGB(22, 22, 32)
            row.BorderSizePixel = 0
            row.Parent = playerListFrame

            local rowCorner = Instance.new("UICorner")
            rowCorner.CornerRadius = UDim.new(0, 8)
            rowCorner.Parent = row

            local nameLbl = Instance.new("TextLabel")
            nameLbl.Size = UDim2.new(1, -160, 1, 0)
            nameLbl.Position = UDim2.new(0, 10, 0, 0)
            nameLbl.BackgroundTransparency = 1
            nameLbl.Text = "👤 " .. plr.Name
            nameLbl.TextColor3 = Color3.fromRGB(220, 220, 240)
            nameLbl.TextSize = 13
            nameLbl.Font = Enum.Font.Gotham
            nameLbl.TextXAlignment = Enum.TextXAlignment.Left
            nameLbl.Parent = row

            -- Bouton TP
            local tpBtn = Instance.new("TextButton")
            tpBtn.Size = UDim2.new(0, 46, 0, 24)
            tpBtn.Position = UDim2.new(1, -158, 0.5, -12)
            tpBtn.BackgroundColor3 = Color3.fromRGB(60, 100, 60)
            tpBtn.BorderSizePixel = 0
            tpBtn.Text = "TP"
            tpBtn.TextColor3 = Color3.fromRGB(200, 255, 200)
            tpBtn.TextSize = 12
            tpBtn.Font = Enum.Font.GothamBold
            tpBtn.Parent = row

            local tpCorner = Instance.new("UICorner")
            tpCorner.CornerRadius = UDim.new(0, 6)
            tpCorner.Parent = tpBtn

            -- Bouton Spectate
            local specBtn = Instance.new("TextButton")
            specBtn.Size = UDim2.new(0, 80, 0, 24)
            specBtn.Position = UDim2.new(1, -105, 0.5, -12)
            specBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 140)
            specBtn.BorderSizePixel = 0
            specBtn.Text = "Spectate"
            specBtn.TextColor3 = Color3.fromRGB(200, 200, 255)
            specBtn.TextSize = 12
            specBtn.Font = Enum.Font.GothamBold
            specBtn.Parent = row

            local specCorner = Instance.new("UICorner")
            specCorner.CornerRadius = UDim.new(0, 6)
            specCorner.Parent = specBtn

            tpBtn.MouseButton1Click:Connect(function()
                local char = LocalPlayer.Character
                local targetChar = plr.Character
                if char and targetChar and targetChar.PrimaryPart then
                    char:SetPrimaryPartCFrame(targetChar.PrimaryPart.CFrame + Vector3.new(0, 3, 0))
                end
            end)

            specBtn.MouseButton1Click:Connect(function()
                if spectateConnection then
                    spectateConnection:Disconnect()
                    spectateConnection = nil
                end
                spectating = true
                selectedPlayer = plr
                currentCamera.CameraType = Enum.CameraType.Custom

                spectateConnection = RunService.RenderStepped:Connect(function()
                    if plr.Character and plr.Character.PrimaryPart then
                        currentCamera.CameraType = Enum.CameraType.Watch
                        currentCamera.CameraSubject = plr.Character:FindFirstChildOfClass("Humanoid")
                    end
                end)
            end)
        end
    end
end

