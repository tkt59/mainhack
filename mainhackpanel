-- ── ESP RAINBOW ──
local function clearESP()
    for _, h in pairs(espObjects) do
        pcall(function() h:Destroy() end)
    end
    espObjects = {}
end
 
local function setupESP()
    clearESP()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hl = Instance.new("SelectionBox")
            hl.Adornee       = plr.Character
            hl.LineThickness = 0.06
            hl.Color3        = Color3.fromRGB(255, 0, 0)
            hl.SurfaceTransparency = 1
            hl.Parent        = game.CoreGui
            espObjects[plr.Name] = hl
        end
    end
end
 
local espRow, espSet = createToggle(miscContent, "🌈  ESP Rainbow", function(state)
    espEnabled = state
    if not state then clearESP() else setupESP() end
end)
 
Players.PlayerAdded:Connect(function(plr)
