local function playOpenAnimation()
    RainbowFrame.BackgroundTransparency = 1
    RainbowFrame.Size = UDim2.new(0, 0, 0, 0)
    RainbowFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
    RainbowFrame.Visible = true
 
    TweenService:Create(RainbowFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 424, 0, 480),
        Position = UDim2.new(0.5, -212, 0.5, -240),
        BackgroundTransparency = 0,
    }):Play()
 
    task.delay(0.15, function()
        for _, t in ipairs(fadables) do
            TweenService:Create(t[1], TweenInfo.new(0.3), {[t[2]] = 0}):Play()
        end
    end)
end
 
local function playCloseAnimation()
    for _, t in ipairs(fadables) do
        TweenService:Create(t[1], TweenInfo.new(0.15), {[t[2]] = 1}):Play()
    end
    task.delay(0.1, function()
        TweenService:Create(RainbowFrame, TweenInfo.new(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            BackgroundTransparency = 1,
        }):Play()
    end)
end
 
playOpenAnimation()
 
