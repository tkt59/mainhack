-- Tous les éléments qu'on fade in/out
local function getAllFadables()
    return {
        {obj = MainFrame,   prop = "BackgroundTransparency", open = 0,   close = 1},
        {obj = Header,      prop = "BackgroundTransparency", open = 0,   close = 1},
        {obj = HeaderFix,   prop = "BackgroundTransparency", open = 0,   close = 1},
        {obj = TabsFrame,   prop = "BackgroundTransparency", open = 0,   close = 1},
        {obj = TitleLabel,  prop = "TextTransparency",       open = 0,   close = 1},
        {obj = SubTitle,    prop = "TextTransparency",       open = 0,   close = 1},
    }
end
 
local function playOpenAnimation()
    RainbowFrame.Size                 = UDim2.new(0, 0, 0, 0)
    RainbowFrame.Position             = UDim2.new(0.5, 0, 0.5, 0)
    RainbowFrame.BackgroundTransparency = 1
    RainbowFrame.Visible              = true
 
    -- Cache aussi le contenu des tabs + tabs buttons pendant l'anim
    ContentFrame.Visible = false
    TabsFrame.Visible    = false
 
    TweenService:Create(RainbowFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size     = UDim2.new(0, 430, 0, 490),
        Position = UDim2.new(0.5, -215, 0.5, -245),
        BackgroundTransparency = 0,
    }):Play()
 
    task.delay(0.15, function()
        for _, t in ipairs(getAllFadables()) do
            TweenService:Create(t.obj, TweenInfo.new(0.25), {[t.prop] = t.open}):Play()
        end
        task.delay(0.1, function()
            ContentFrame.Visible = true
            TabsFrame.Visible    = true
        end)
    end)
end
 
local function playCloseAnimation()
    -- On cache immédiatement les tabs + contenu pour éviter qu'ils restent visibles
    ContentFrame.Visible = false
    TabsFrame.Visible    = false
 
    for _, t in ipairs(getAllFadables()) do
        TweenService:Create(t.obj, TweenInfo.new(0.12), {[t.prop] = t.close}):Play()
    end
 
    task.delay(0.08, function()
        TweenService:Create(RainbowFrame, TweenInfo.new(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Size     = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            BackgroundTransparency = 1,
        }):Play()
        task.delay(0.3, function()
            RainbowFrame.Visible = false
        end)
    end)
end
 
playOpenAnimation()
 
